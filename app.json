      "description": "WhatsApp support group link.",
      "value": "https://chat.whatsapp.com/PLACEHOLDER"
    },
    "WHATSAPP_CHANNEL": {
      "description": "WhatsApp channel link.",
      "value": "https://whatsapp.com/channel/PLACEHOLDER"
    },
    "TELEGRAM": {
      "description": "Telegram support link.",
      "value": "https://t.me/N0rd_X"
    },
    "DISCORD": {
      "description": "Discord support link.",
      "value": "https://discord.com/PLACEHOLDER"
